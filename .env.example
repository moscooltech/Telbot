# Required: Telegram Bot Token from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Required: OpenRouter API Key (Free tier handles Gemini Flash 2.0)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Pollinations API Key (for higher-tier access)
POLLINATIONS_API_KEY=your_pollinations_api_key_here

# Optional: Bytez API Key (Fallback Image Generation SDK)
BYTEZ_API_KEY=your_bytez_api_key_here

# Optional: Render Webhook URL (Required for app.py mode)
WEBHOOK_URL=
PORT=10000
